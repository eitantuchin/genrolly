# --- Genrolly backend env ---

# Comma-separated list of accepted x-api-key values from the extension.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
GENROLLY_API_KEYS=replace-me-dev-key

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Resend (email sending)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=jane@yourdomain.com
RESEND_FROM_NAME=Jane @ Pythonacademy

# Supabase
SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...   # service role, server-side only

# YouTube Data API (optional — enables backend-side comment fetching)
YOUTUBE_API_KEY=

# Stripe (optional — paid plans)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# CORS origins for the extension. Chrome extensions show up as
# chrome-extension://<id>; "*" is fine for early dev.
CORS_ORIGINS=*
