{
  "manifest_version": 3,
  "name": "Genrolly",
  "version": "0.1.0",
  "description": "Lead gen for course creators. Generate leads from Apollo.io, create personalized cold emails with AI, and send via Gmail.",
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/genrolly-logo.png",
      "48": "icons/genrolly-logo.png",
      "128": "icons/genrolly-logo.png"
    },
    "default_title": "Genrolly"
  },
  "icons": {
    "16": "icons/genrolly-logo.png",
    "48": "icons/genrolly-logo.png",
    "128": "icons/genrolly-logo.png"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "options_page": "options/options.html",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "http://localhost/*",
    "https://*.up.railway.app/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["popup/*", "options/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
